# .env.example
# ------------------------------------------------------------------------------
# Copia este archivo como .env y ajusta los valores. Las variables se leen con
# getenv() en config/config.php. (Para que .env se cargue automáticamente puedes
# añadir vlucas/phpdotenv más adelante; por ahora exporta las variables en tu
# entorno o edita config.php directamente.)
# ------------------------------------------------------------------------------

# Identidad de la app. 👉 Define aquí el nombre cuando lo tengas.
APP_NAME="BioBoyacá"
APP_ENV=local
APP_DEBUG=true
APP_BASE_URL=http://localhost:8000

# Motor de base de datos activo: json | postgres | mongo
DB_DRIVER=json

# PostgreSQL (cuando actives el driver 'postgres')
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DBNAME=proyecto_henry
PG_USER=postgres
PG_PASSWORD=

# MongoDB / cluster (cuando actives el driver 'mongo')
MONGO_URI="mongodb://127.0.0.1:27017"
MONGO_DB=proyecto_henry
